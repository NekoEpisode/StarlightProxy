<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" shutdownHook="disable">
    <Properties>
        <Property name="LOG_PATH">logs</Property>
        <!-- 主日志格式: [HH:mm:ss INFO]: 消息 -->
        <Property name="LOG_PATTERN">[%d{HH:mm:ss} %-5level]: %msg%n</Property>
        <!-- 主日志格式(带颜色): INFO/DEBUG=白色, WARN=黄色, ERROR=红色 -->
        <Property name="LOG_PATTERN_COLOR">%highlight{[%d{HH:mm:ss} %-5level]: %msg%n}{FATAL=red, ERROR=red, WARN=yellow, INFO=white, DEBUG=white, TRACE=white}</Property>
        <!-- 插件日志格式: [HH:mm:ss INFO] [插件名]: 消息 -->
        <Property name="PLUGIN_PATTERN">[%d{HH:mm:ss} %-5level] [%logger{1}]: %msg%n</Property>
        <!-- 插件日志格式(带颜色) -->
        <Property name="PLUGIN_PATTERN_COLOR">%highlight{[%d{HH:mm:ss} %-5level] [%logger{1}]: %msg%n}{FATAL=red, ERROR=red, WARN=yellow, INFO=white, DEBUG=white, TRACE=white}</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN_COLOR}" />
        </Console>

        <Console name="PluginConsole" target="SYSTEM_OUT">
            <PatternLayout pattern="${PLUGIN_PATTERN_COLOR}" />
        </Console>

        <RollingFile name="FileLogger"
                     fileName="${LOG_PATH}/app.log"
                     filePattern="${LOG_PATH}/archive/app-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}" />
            <Policies>
                <TimeBasedTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <RollingFile name="PluginFileLogger"
                     fileName="${LOG_PATH}/plugins.log"
                     filePattern="${LOG_PATH}/archive/plugins-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${PLUGIN_PATTERN}" />
            <Policies>
                <TimeBasedTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- 主包日志 -->
        <Logger name="io.slidermc.starlight" level="info" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Logger>

        <!-- 插件日志，前缀 plugin.<插件名>，匹配所有已注册插件的 Logger -->
        <Logger name="plugin" level="info" additivity="false">
            <AppenderRef ref="PluginConsole"/>
            <AppenderRef ref="PluginFileLogger"/>
        </Logger>

        <!-- Netty 日志 -->
        <Logger name="io.netty" level="warn" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Logger>

        <!-- Root 日志（只记录警告和错误） -->
        <Root level="warn">
            <AppenderRef ref="FileLogger"/>
        </Root>
    </Loggers>
</Configuration>